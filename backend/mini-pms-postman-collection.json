    {
      "name": "Tasks",
      "item": [
        {
          "name": "Add Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('task_id', json.data.task._id);",
                  "  pm.test('Task created', () => pm.response.to.have.status(201));",
                  "  pm.test('task_id saved', () => pm.expect(json.data.task._id).to.be.a('string'));",
                  "}"
