          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/projects/000000000000000000000000", "host": ["{{base_url}}"], "path": ["api", "projects", "000000000000000000000000"] }
          }
